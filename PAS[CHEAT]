-- [[ WindUI Library Initialization ]]
local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- Create the Main Window
local Window = WindUI:CreateWindow({
    Title = "Paint And Seek Cheat [BETA]",
    SubTitle = "by mikmikuser123",
    Author = "Universal",
    Size = UDim2.fromOffset(550, 380),
    HasOutline = true,
    Theme = "Dark"
})

-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

-- Remotes
local GameRemotes = ReplicatedStorage:WaitForChild("GameRemotes")
local JoinAsSeekerResponse = GameRemotes:WaitForChild("JoinAsSeekerResponse")

-- Toggle States
local alwaysSeekerEnabled = false
local autoTauntEnabled = false
local espEnabled = false
local espObjects = {}

-- [[ TAB 1: Main Features ]]
local MainTab = Window:Tab({
    Title = "Main",
    Icon = "rbxassetid://10723415903"
})

MainTab:Paragraph({
    Title = "Welcome!",
    Desc = "Paint and Seek Hub. Make sure to report bugs to mikmikuser123!"
})

-- One-time trigger button
MainTab:Button({
    Title = "Be A Seeker",
    Desc = "Requests to join as a seeker once.",
    Callback = function()
        local args = { true }
        JoinAsSeekerResponse:FireServer(unpack(args))
        print("[WindUI] Requested Seeker once.")
    end
})

-- Continuous loop toggle
MainTab:Toggle({
    Title = "Always Be A Seeker",
    Desc = "Loops the seeker request continuously.",
    Value = false,
    Callback = function(state)
        alwaysSeekerEnabled = state
        
        if alwaysSeekerEnabled then
            task.spawn(function()
                local args = { true }
                while alwaysSeekerEnabled do
                    JoinAsSeekerResponse:FireServer(unpack(args))
                    task.wait(1) -- Adjust delay if needed
                end
            end)
            print("[WindUI] Always Be Seeker loop activated.")
        else
            print("[WindUI] Always Be Seeker loop deactivated.")
        end
    end
})

MainTab:Toggle({
    Title = "Auto Taunt",
    Desc = "Automatically triggers taunts periodically.",
    Value = false,
    Callback = function(state)
        autoTauntEnabled = state
        
        if autoTauntEnabled then
            task.spawn(function()
                local args = { true }
                while autoTauntEnabled do
                    JoinAsSeekerResponse:FireServer(unpack(args))
                    task.wait(1) 
                end
            end)
            print("[WindUI] Auto Taunt enabled.")
        else
            print("[WindUI] Auto Taunt disabled.")
        end
    end
})


-- [[ TAB 2: Player Adjustments ]]
local PlayerTab = Window:Tab({
    Title = "Player",
    Icon = "rbxassetid://10747373151"
})

-- WalkSpeed Slider
